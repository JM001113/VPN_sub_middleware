# Service bind port
SUB_PORT=8080

# Upstream 3x-ui subscription source
BASE_SUB_PORT=2053
BASE_SUB_URL=sub
UPSTREAM_HOST=127.0.0.1

# YOUR subscription source
BASE_SUB_SERVICE_URL=sub2

# Rewrites applied to every supported link
TARGET_HOST=inbound.anti-vpn.ru
TARGET_PORT=443
# Optional: when set, adds/updates ?sni=...
# TARGET_SNI=server.example.com

# Upstream request timeout
UPSTREAM_TIMEOUT_SECONDS=10
